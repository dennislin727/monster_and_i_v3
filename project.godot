; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="怪物與我v3"
run/main_scene="uid://duan0a8lqkhxf"
config/features=PackedStringArray("4.4", "Mobile")
config/icon="res://icon.svg"

[autoload]

GlobalBalance="*res://src腳本/autoload管理員/GlobalBalance.gd"
DataManager="*res://src腳本/autoload管理員/DataManager.gd"
SignalBus="*res://src腳本/autoload管理員/SignalBus.gd"
PetManager="*res://src腳本/autoload管理員/PetManager.gd"
InventoryManager="*res://src腳本/autoload管理員/InventoryManager.gd"
NpcInteractionManager="*res://src腳本/autoload管理員/NpcInteractionManager.gd"
NpcStateManager="*res://src腳本/autoload管理員/NpcStateManager.gd"
DialogueManager="*res://src腳本/autoload管理員/DialogueManager.gd"
HomeManager="*res://src腳本/autoload管理員/HomeManager.gd"
PlayerHintCatalog="*res://src腳本/autoload管理員/PlayerHintCatalog.gd"
SaveGameManager="*res://src腳本/autoload管理員/SaveGameManager.gd"
DiaryManager="*res://src腳本/autoload管理員/DiaryManager.gd"
ProgressionManager="*res://src腳本/autoload管理員/ProgressionManager.gd"
HomesteadStationDialogue="*res://src腳本/autoload管理員/HomesteadStationDialogue.gd"

[display]

window/size/viewport_width=360
window/size/viewport_height=640
window/size/window_width_override=360
window/size/window_height_override=640
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/virtual_joystick/plugin.cfg")

